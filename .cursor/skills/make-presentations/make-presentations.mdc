### Particle / Decorative JS Effects (optional, for hero slides)

```js
// Simple floating orbs (add to script block)
function createOrbs(slideEl, count = 6) {
  for (let i = 0; i < count; i++) {
    const orb = document.createElement('div');
    orb.className = 'orb';
    Object.assign(orb.style, {
      width: `${80 + Math.random() * 200}px`,
      height: orb.style.width,
      left: `${Math.random() * 100}%`,
      top: `${Math.random() * 100}%`,
      animationDuration: `${6 + Math.random() * 10}s`,
      animationDelay: `${Math.random() * -8}s`,
    });
    slideEl.appendChild(orb);
  }
}
```
```css
.orb {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
