## Required Navigation Script

```js
(function () {
  const slides = Array.from(document.querySelectorAll('.slide'));
  let current = 0;
  let isAnimating = false;

  function goTo(index, direction) {
    if (isAnimating || index < 0 || index >= slides.length) return;
    isAnimating = true;

    const prev = slides[current];
    const next = slides[index];

    document.body.setAttribute('data-dir', direction); // 'next' or 'prev'
    prev.classList.remove('active');
    prev.classList.add('leaving');
    next.classList.add('active');

    prev.addEventListener('animationend', () => {
      prev.classList.remove('leaving');
      isAnimating = false;
    }, { once: true });

    current = index;
  }

  document.getElementById('next').addEventListener('click', () => goTo(current + 1, 'next'));
  document.getElementById('prev').addEventListener('click', () => goTo(current - 1, 'prev'));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') goTo(current + 1, 'next');
    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') goTo(current - 1, 'prev');
  });

  // If using Lucide icons:
  // if (window.lucide) lucide.createIcons();
})();
```

